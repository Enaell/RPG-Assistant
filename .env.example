# ─── Discord Bot ────────────────────────────────────────────
# https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

DISCORD_BOT_AUTHORIZATION_URI=https://discord.com/oauth2/authorize?client_id=1520134531141599334&permissions=3213312&integration_type=0&scope=bot+applications.commands
# Guild (server) ID — used to register slash commands instantly during dev
# In production, remove this to use global commands (takes ~1h to propagate)
DISCORD_GUILD_ID=your_guild_id_here

# ─── STT — Voxtral / Mistral API (Phase 1-2) ────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── Audio Output ──────────────────────────────────────────
# 'local' : enregistre les .wav sur disque (développement / debug UNIQUEMENT)
# 'stt'   : envoie via le hook STT (Phase 1+, intégration packages/stt-client)
AUDIO_OUTPUT_MODE=local
# Répertoire de destination quand AUDIO_OUTPUT_MODE=local
RECORDINGS_DIR=./recordings

# ─── Environment ────────────────────────────────────────────
NODE_ENV=development
